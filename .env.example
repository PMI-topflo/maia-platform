# Supabase
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_secret>
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co   # same value as SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_public_key>

# Session
MAIA_SESSION_SECRET=<random-256-bit-hex>

# Email — Resend (primary)
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=<resend-webhook-signing-secret>

# Email — Gmail OAuth (fallback + MAIA inbound)
GMAIL_CLIENT_ID=<oauth-client-id>
GMAIL_CLIENT_SECRET=<oauth-client-secret>
GMAIL_REFRESH_TOKEN=<oauth-refresh-token>
GMAIL_PUBSUB_TOPIC=projects/<project>/topics/<topic>
GMAIL_PUBSUB_SECRET=<pubsub-push-token>

# SMS / WhatsApp — Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX       # SMS sender number
TWILIO_WHATSAPP_NUMBER=+1XXXXXXXXXX    # WhatsApp-enabled number (may differ)
TWILIO_OTP_TEMPLATE_SID=HX...          # Approved WhatsApp OTP content template
TWILIO_LEDGER_NUDGE_TEMPLATE_SID=HX... # Approved WhatsApp "reply ledger" content template (English only)
TWILIO_VOICE_INFO_SEND_TEMPLATE_SID=HX... # Approved WhatsApp "reply and I'll send it" content template for the general voice→WhatsApp cross-channel case (English only)
WEBHOOK_VERIFY_TOKEN=<twilio-webhook-verify-token>

# AI
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...                     # Gemini Flash — document extraction (lease + Sunbiz parsing on /apply)

# Payments — Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...        # From Stripe dashboard → Webhooks
STRIPE_PRICE_INDIVIDUAL=price_...      # Stripe Price ID for individual applications ($150)
STRIPE_PRICE_ADDITIONAL=price_...      # Stripe Price ID for additional-resident applications ($150)
STRIPE_PRICE_COUPLE=price_...          # Stripe Price ID for couple applications ($150)
STRIPE_PRICE_COMMERCIAL=price_...      # Stripe Price ID for commercial applications, per principal ($150)
STRIPE_PRICE_INTERNATIONAL=price_...   # Stripe Price ID for Canadian/International applications ($150)

# Background checks — Checkr TENANT Screening API (checkr-tenant-api-docs.redocly.app;
# replaces the dead ApplyCheck integration, which had no public API). Key format
# is ckr_sk_test_... (dev) or ckr_sk_live_... (prod) — sent as a Bearer token,
# NOT HTTP Basic auth. There is no embeddable consent widget: Checkr emails the
# applicant a link to their own hosted page to finish consent/questionnaire.
CHECKR_API_KEY=...
# Package slug from your Checkr Dashboard "Packages" tab (lowercase, spaces
# → underscores). One tier for everyone -- "Essential" ($34.99/report):
# criminal history, full eviction history, credit score, credit report.
# Used for individual/couple/additionalResident/commercial-principal AND
# international applicants alike (there is no distinct international
# package — Checkr's international product is à la carte per-country
# pricing, not a package slug; international applicants' country-specific
# gap is covered by applicant-uploaded documents instead, see ApplicationForm).
# Price doesn't include Checkr's pass-through fees (e.g. court-record
# retrieval costs that vary by jurisdiction) — those are billed on top by Checkr.
CHECKR_PACKAGE_RESIDENTIAL=...
# Signs the inbound webhook (/api/checkr-webhook) — set the same value in the
# Checkr Dashboard's webhook config. Verify the exact header/scheme against
# docs.checkr.com before relying on it in production (see lib/screening/checkr.ts).
CHECKR_WEBHOOK_SECRET=...

# Rentvine property management sync
RENTVINE_BASE_URL=https://api.rentvine.com/v1
RENTVINE_ACCESS_KEY=...
RENTVINE_SECRET=...

# Internal
NEXT_PUBLIC_APP_URL=https://www.pmitop.com    # No trailing slash; used in internal fetch() calls and message links
INTERNAL_API_SECRET=<random-secret>            # Guards /api/trigger-applycheck from external calls
CRON_SECRET=<random-secret>                    # Vercel injects this automatically for scheduled cron routes

# Staff routing emails
STAFF_EMAIL=...@topfloridaproperties.com
STAFF_ALERT_EMAIL=PMI@topfloridaproperties.com
LEASING_EMAIL=...@topfloridaproperties.com
MAINTENANCE_EMAIL=...@topfloridaproperties.com
EMERGENCY_EMAIL=...@topfloridaproperties.com
EMERGENCY_PHONE=+1XXXXXXXXXX
AR_EMAIL=...@topfloridaproperties.com          # Accounts receivable

# Dialpad API key. Get from Dialpad admin → API Keys.
# Required OAuth scopes:
#   users:list, numbers:list, calls:list, webhooks:create, subscriptions:create,
#   message_content_export:all (SMS body content),
#   recordings_export (call recording URLs)
DIALPAD_API_KEY=

# Invoice intake → Google Drive mirror (renamed PDFs land in INVOICE TO INPUT)
# Service-account JSON (whole file, single line). NOTE: service accounts have
# NO Drive storage quota of their own, so one of the two options below is
# REQUIRED for uploads to succeed (otherwise: "Service Accounts do not have
# storage quota").
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
INVOICE_INTAKE_DRIVE_FOLDER_ID=<drive-folder-id>   # default: My Drive › Accounting › INVOICE TO INPUT
# Option A (recommended): domain-wide delegation. Set this to a Workspace user
# email; the mirror acts AS that user (who has Drive quota) so files are owned
# by them and land in their My Drive folder. Requires authorizing the service
# account's client ID for the scope https://www.googleapis.com/auth/drive in
# the Google Workspace Admin console (Security → API Controls → Domain-wide
# Delegation). Leave unset to instead use a Shared Drive (add the SA as a
# member and point INVOICE_INTAKE_DRIVE_FOLDER_ID at a folder inside it).
GOOGLE_DRIVE_IMPERSONATE=...@topfloridaproperties.com
